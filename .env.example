# PostgreSQL runs in Docker as `db`. dev.sh rewrites this host to localhost
# when the Go API runs directly on the development machine.
DATABASE_URL=postgres://postgres:postgres@db:5432/dc_go?sslmode=disable

# Use a unique production secret. It must be at least 32 characters and contain
# at least three of: uppercase, lowercase, digits, and symbols.
JWT_SECRET=ReplaceThisWithAStrong32CharacterSecret!123

# Redis is password-protected even in local Docker. dev.sh rewrites the service
# hostname to localhost when the Go API runs directly on the host.
REDIS_PASSWORD=ReplaceThisWithARedisPassword!123
REDIS_URL=redis://:ReplaceThisWithARedisPassword!123@redis:6379/0

# SeaweedFS provides S3-compatible object storage. Generic S3 names keep the
# application portable to AWS S3 or another provider later.
S3_ENDPOINT=http://seaweedfs:8333
S3_ACCESS_KEY=dcgo
S3_SECRET_KEY=ReplaceThisWithAnS3Secret!123
S3_BUCKET=dc-go
S3_REGION=us-east-1
S3_USE_SSL=false
S3_FORCE_PATH_STYLE=true
